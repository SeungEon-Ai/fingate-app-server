# Gemini API 키 - https://aistudio.google.com/apikey 에서 발급
GEMINI_API_KEY=your_gemini_api_key_here

# Gemini 모델 (기본: Flash-Lite, 무료 1500 RPD)
GEMINI_MODEL=gemini-2.5-flash-lite

# 관리자 토큰 - cron 엔드포인트 보호용. 임의의 긴 문자열로 설정
# 예시 생성: python -c "import secrets; print(secrets.token_urlsafe(32))"
ADMIN_TOKEN=change_this_to_random_long_string

# DB 경로 (로컬: SQLite 파일. Render에선 자동으로 /tmp 또는 디스크 마운트 경로로 변경 가능)
DATABASE_URL=sqlite:///./fingate.db

# CORS 허용 origin (개발 시 *, 배포 시 앱 도메인만)
CORS_ORIGINS=*

# 환경 (development / production)
ENV=development

# 로그 레벨
LOG_LEVEL=INFO
